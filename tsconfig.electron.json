{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "lib": ["ES2022"],
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "allowJs": false,
    "outDir": "./electron",
    "rootDir": ".",
    "removeComments": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "main.cts",
    "preload.cts",
    "backend.cts",
    "contracts.cts",
    "repository.cts",
    "migrations.cts",
    "sqlite.cts",
    "scrapers.cts",
    "shared/**/*"
  ],
  "exclude": ["node_modules", "dist", "src", "electron", "desktop", "desktopsrc"]
}
